# FinanceOS WhatsApp — Variables de entorno
# Copia este archivo como .env y rellena los valores

# ── Twilio ──────────────────────────────────────────────────────────────────
# Obtén estos en: console.twilio.com → Account Info
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número de WhatsApp del sandbox de Twilio (Sandbox: whatsapp:+14155238886)
# Cuando pases a producción será tu número aprobado
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Anthropic Claude ─────────────────────────────────────────────────────────
# Obtén en: console.anthropic.com → API Keys
ANTHROPIC_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ─────────────────────────────────────────────────────────────────
# Obtén en: app.supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
